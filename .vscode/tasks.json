{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "make all",
      "type": "shell",
      "command": "make",
      "group": "build",
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "make debug",
      "type": "shell",
      "command": "make",
      "args": ["clean", "all", "CXXFlag=-g -O0"],
      "group": "build",
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "make clean",
      "type": "shell",
      "command": "make",
      "args": ["clean"],
      "problemMatcher": []
    },
    {
      "label": "make run",
      "type": "shell",
      "command": "./app/build/app",
      "dependsOn": "make all",
      "problemMatcher": []
    },
    {
      "label": "make asm debug",
      "type": "shell",
      "command": "make",
      "args": [
        "clean",
        "app/build/app",
        "CXXFlag=-g -O0",
        "ASMFlag=-f elf64 -g -F dwarf"
      ],
      "group": "build",
      "problemMatcher": ["$gcc"]
    }
  ]
}
